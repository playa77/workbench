# ==========================================
# Citizen — Environment Template
# Copy to .env and fill in real values.
# ==========================================
# Semantic Version: 0.1.0

# Database (required)
# PostgreSQL 16 with pgvector extension.
DATABASE_URL=postgresql+asyncpg://local_user:local_pass@localhost:5432/citizen_db

# LLM Routing (required)
# OpenRouter API key — only normalized text is sent to external providers.
OPENROUTER_API_KEY=

# LLM model selection (defaults match the deterministic fallback chain)
PRIMARY_MODEL=deepseek/deepseek-v4-flash
FALLBACK_MODEL_1=deepseek/deepseek-v4-flash
FALLBACK_MODEL_2=/openrouter/free

# Triages and final-generation models (optional — overrides PRIMARY_MODEL for those stages)
TRIAGE_MODEL=
FINAL_MODEL=

# Retry and timeout behaviour for the OpenRouter client
MAX_RETRIES=1
REQUEST_TIMEOUT=25

# Per-stage timeouts (seconds)
TRIAGE_TIMEOUT_SEC=20
FINAL_TIMEOUT_SEC=75
EMBEDDING_TIMEOUT_SEC=15

# Connection pool size for async SQLAlchemy engine
DB_POOL_SIZE=10

# Document ingestion limits
MAX_FILE_SIZE_MB=25
OCR_DPI=300
OCR_JPG_QUALITY=84
OCR_CONTRAST_FACTOR=2.0
OCR_BW_THRESHOLD=128
OCR_SYNTHESIS_MODEL=deepseek/deepseek-v4-flash

# Embedding / retrieval config
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIM=1536
TOP_K_RETRIEVAL=6
MAX_COSINE_DISTANCE=0.85

# Pipeline hard limit (seconds)
PIPELINE_TIMEOUT_SEC=120

# Prompt / token budgeting — prevent giant prompts from exploding latency (WP-010)
MAX_TRIAGE_INPUT_CHARS=8000
MAX_FINAL_INPUT_CHARS=5000
MAX_CHUNK_CONTEXT_CHARS=7000
MAX_CHUNKS_FOR_FINAL=6

# Application logging
LOG_LEVEL=INFO

# CORS — allowed origins for the static frontend
CORS_ORIGINS=["http://localhost:8000"]

# Rate limiting (in-memory, sliding window)
# Set both to 0 to disable rate limiting entirely.
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Consent / disclaimer
DISCLAIMER_VERSION=v0.1.0
