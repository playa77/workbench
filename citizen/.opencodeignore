# Narrows context to source-code-only.

# Version Control
.git/

# Python / Bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environments
.venv/
venv/
ENV/
env/
.env_python/

# Environment Variables / Secrets
.env
.env.local
.env.development
.env.production
.secret_salt
*.pem

# Cache Directories
.mypy_cache/
.pytest_cache/
.ruff_cache/
.pyre/

# Build & Distribution
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/

# Lock Files (auto-generated, not source)
uv.lock
poetry.lock
Pipfile.lock

# Database & State Files
*.sqlite3
*.sqlite
*.db
*.db-journal
*.db-wal
*.db-shm
pgdata/
postgres_data/
postgresql/data/
*.pid
postmaster.pid

# Testing Artifacts
.benchmarks/
.coverage
.coverage.*
htmlcov/
.tox/
coverage.xml

# Logs & Uploads
logs/
*.log
uploads/
tmp/
temp/

