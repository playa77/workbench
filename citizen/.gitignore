# ==========================================
# Citizen (v1.0) - .gitignore
# ==========================================

# Python / Bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environments
.venv/
venv/
ENV/
env/
.env_python/

# Environment Variables / Secrets
# (Explicitly ignoring .env to prevent secret leakage)
.env
.env.local
.env.development
.env.production
*.pem
.secret_salt 

# Logs
# (As specified in Document 2: Project Structure)
logs/
*.log

# Testing & Coverage
.benchmarks
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
*.py,cover

# Type Checking
.mypy_cache/
.pyre/
.ruff_cache/

# Database / State
*.sqlite3
*.sqlite
*.db
*.db-journal
*.db-wal
*.db-shm

# PostgreSQL local development / testing
postgresql.conf
pg_hba.conf
pgdata/
postgres_data/
postgresql/data/
.pgpass
.pg_service.conf
*.pid
postmaster.pid
.s.PGSQL.*

# (Note: alembic.ini and alembic/versions/ are tracked, do not ignore them)

# OS / IDE Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Build / Distribution
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Uploads / Ephemeral Data
# (Prevent accidental commit of user documents)
uploads/
tmp/
temp/

# misc stuff
ideas/
ideas.txt
archive.zip
citizen.zip
.qwen/
QWEN.md
docker-compose.yml  # take out before release
deploy_db.sh
