# Workbench Docker Deployment — Required Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
#
# Generate a secure ENCRYPTION_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# PostgreSQL credentials (REQUIRED)
POSTGRES_USER=workbench
POSTGRES_PASSWORD=
POSTGRES_DB=workbench

# AES-256-GCM encryption key — 64 hex characters (REQUIRED)
ENCRYPTION_KEY=

# Optional: server-wide OpenRouter API key fallback
OPENROUTER_API_KEY=

# Optional: server-wide Brave Search API key fallback (used by Deep Research agent)
# Per-user Brave keys saved in Settings take precedence over this global fallback.
BRAVE_SEARCH_API_KEY=
