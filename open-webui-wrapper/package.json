{
  "name": "owui-wrapper",
  "version": "0.1.0",
  "main": "dist/main/index.js",
  "description": "Desktop wrapper for Open WebUI",
  "author": "Dave Martin <playa77@gmail.com>",
  "homepage": "https://github.com/playa77/open-webui-wrapper",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron --no-sandbox .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "dist:deb": "npm run build && electron-builder --linux deb",
    "dist:appimage": "npm run build && electron-builder --linux AppImage",
    "dist": "npm run build && electron-builder --linux deb AppImage"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
